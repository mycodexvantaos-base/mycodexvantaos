{
  "audit": {
    "enabled": true,
    "level": "comprehensive",
    "scan_interval": "daily",
    "reporting": {
      "enabled": true,
      "formats": [
        "json",
        "pdf"
      ],
      "recipients": [
        "security@mycodexvantaos.com"
      ]
    }
  },
  "vulnerability_scan": {
    "enabled": true,
    "tools": [
      "snyk",
      "npm audit",
      "owasp"
    ],
    "severity_threshold": "medium",
    "auto_fix": true
  },
  "access_control": {
    "enabled": true,
    "authentication": "jwt",
    "authorization": "rbac",
    "session_timeout": 3600,
    "max_login_attempts": 5
  },
  "data_protection": {
    "encryption_in_transit": true,
    "encryption_at_rest": true,
    "key_management": "aws-kms",
    "backup_enabled": true,
    "backup_interval": "daily",
    "retention_days": 90
  }
}