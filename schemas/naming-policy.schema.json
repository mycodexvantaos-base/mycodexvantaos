{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/schemas/naming-policy.schema.json",
  "title": "MyCodexVantaOS Naming Policy",
  "description": "Formal naming rules for mycodexvantaos platform. Source of truth for all CI validators. Based on naming-spec-v1.md 13.",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "rules": {
      "type": "object",
      "description": "All naming validation rules keyed by rule-id",
      "properties": {
        "service-id": {
          "type": "object",
          "description": "5.1 — Service identifier. Must start with mycodexvantaos- followed by domain and capability segments.",
          "properties": {
            "pattern": { "type": "string", "const": "^mycodexvantaos-[a-z0-9]+(?:-[a-z0-9]+)+$" },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "5.1" },
            "examples": {
              "type": "array",
              "items": { "type": "string" },
              "examples": [["mycodexvantaos-core-kernel", "mycodexvantaos-ai-embedding", "mycodexvantaos-data-vector-store"]]
            },
            "counterExamples": {
              "type": "array",
              "items": { "type": "string" },
              "examples": [["core-kernel", "mycodexvantaos_core_kernel", "mycodexvantaos-core-kernel-v2", "mycodexvantaos-ai-embedding-prod"]]
            }
          }
        },
        "package-short-id": {
          "type": "object",
          "description": "5.2 — Package short id. Derived from service-id by removing the mycodexvantaos- prefix.",
          "properties": {
            "pattern": { "type": "string", "const": "^[a-z0-9]+(?:-[a-z0-9]+)+$" },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "5.2" },
            "derivationRule": { "type": "string", "const": "strip-prefix:mycodexvantaos-" }
          }
        },
        "package-name": {
          "type": "object",
          "description": "7.1 — npm/pnpm scoped package name.",
          "properties": {
            "pattern": { "type": "string", "const": "^@mycodexvantaos/[a-z0-9]+(?:-[a-z0-9]+)+$" },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "7.1" },
            "derivationRule": { "type": "string", "const": "@mycodexvantaos/{package-short-id}" }
          }
        },
        "capability-id": {
          "type": "object",
          "description": "5.5 — Must be a member of the canonical capability set. Vendor names forbidden.",
          "properties": {
            "pattern": {
              "type": "string",
              "const": "^(database|storage|auth|queue|state-store|secrets|repo|deploy|validation|security|observability|notification|scheduler|vector-store|embedding|llm|graph|cache|search)$"
            },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "5.5" },
            "allowedValues": {
              "type": "array",
              "items": { "type": "string" },
              "const": [
                "database", "storage", "auth", "queue", "state-store",
                "secrets", "repo", "deploy", "validation", "security",
                "observability", "notification", "scheduler", "vector-store",
                "embedding", "llm", "graph", "cache", "search"
              ]
            }
          }
        },
        "provider-instance": {
          "type": "object",
          "description": "8.1 — Provider instance: <capability-id>-<provider-name>. Capability must come first.",
          "properties": {
            "pattern": {
              "type": "string",
              "const": "^(database|storage|auth|queue|state-store|secrets|repo|deploy|validation|security|observability|notification|scheduler|vector-store|embedding|llm|graph|cache|search)-[a-z0-9-]+$"
            },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "8.1" }
          }
        },
        "env-var": {
          "type": "object",
          "description": "7.2 — Environment variable. MYCODEXVANTAOS_ prefix required. ORCH_ prefix deprecated.",
          "properties": {
            "pattern": { "type": "string", "const": "^MYCODEXVANTAOS_[A-Z0-9_]+$" },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "7.2" },
            "deprecatedPattern": { "type": "string", "const": "^ORCH_" }
          }
        },
        "urn": {
          "type": "object",
          "description": "7.5 — RFC 8141 compatible URN. No version in identifier segment.",
          "properties": {
            "pattern": { "type": "string", "const": "^urn:mycodexvantaos:[a-z-]+:[a-z-]+:[a-z0-9-]+$" },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "7.5" },
            "allowedTypes": {
              "type": "array",
              "const": ["capability", "provider", "manifest", "policy", "exception", "audit"]
            }
          }
        },
        "vector-collection": {
          "type": "object",
          "description": "9.2 — Vector collection: <service-id>--<purpose>--<embedding-model-alias>",
          "properties": {
            "pattern": { "type": "string", "const": "^mycodexvantaos-[a-z0-9]+(?:-[a-z0-9]+)+--[a-z0-9-]+--[a-z0-9-]+$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.2" }
          }
        },
        "embedding-model-alias": {
          "type": "object",
          "description": "9.3 — Embedding model alias: <provider>--<model-name>--<dimension>d",
          "properties": {
            "pattern": { "type": "string", "const": "^[a-z0-9-]+--[a-z0-9-]+--[0-9]+d$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.3" }
          }
        },
        "retrieval-pipeline-id": {
          "type": "object",
          "description": "9.4 — Retrieval pipeline: retrieval--<strategy>--<store-type>",
          "properties": {
            "pattern": { "type": "string", "const": "^retrieval--[a-z0-9-]+--[a-z0-9-]+$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.4" }
          }
        },
        "search-index-id": {
          "type": "object",
          "description": "9.5 — Search index: idx--<service-id>--<field>--<analyzer>",
          "properties": {
            "pattern": { "type": "string", "const": "^idx--mycodexvantaos-[a-z0-9]+(?:-[a-z0-9]+)+--[a-z0-9-]+--[a-z0-9-]+$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.5" }
          }
        },
        "graph-node-id": {
          "type": "object",
          "description": "9.6 — Graph node: <service-id>--<entity-type>--<natural-key-normalized>",
          "properties": {
            "pattern": { "type": "string", "const": "^mycodexvantaos-[a-z0-9]+(?:-[a-z0-9]+)+--[a-z0-9-]+--[a-z0-9-]+$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.6" }
          }
        },
        "graph-db-index-id": {
          "type": "object",
          "description": "10.3 — Graph DB index: graph-idx--<service-id>--<label>--<property>",
          "properties": {
            "pattern": { "type": "string", "const": "^graph-idx--mycodexvantaos-[a-z0-9]+(?:-[a-z0-9]+)+--[a-z0-9-]+--[a-z0-9-]+$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "10.3" }
          }
        },
        "timestamped-id": {
          "type": "object",
          "description": "9.8 — Auto-generated timestamped id: <prefix>--<YYYYMMDD>--<random6>",
          "properties": {
            "pattern": { "type": "string", "const": "^[a-z0-9-]+--[0-9]{8}--[a-z0-9]{6}$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.8" }
          }
        },
        "content-addressed-id": {
          "type": "object",
          "description": "9.9 — Content-addressed id: <prefix>--sha256-<first12>",
          "properties": {
            "pattern": { "type": "string", "const": "^[a-z0-9-]+--sha256-[a-f0-9]{12}$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.9" }
          }
        },
        "uuid-based-id": {
          "type": "object",
          "description": "9.10 — UUID-based id: <prefix>--<uuid-without-dashes>",
          "properties": {
            "pattern": { "type": "string", "const": "^[a-z0-9-]+--[a-f0-9]{32}$" },
            "enforcement": { "type": "string", "const": "soft" },
            "specRef": { "type": "string", "const": "9.10" }
          }
        },
        "forbidden-legacy-prefix": {
          "type": "object",
          "description": "4 — Forbidden legacy organization prefixes. Must not appear in any resource name.",
          "properties": {
            "pattern": { "type": "string", "const": "^(mycodexvanta-os|codexvanta|codexvanta-os)" },
            "enforcement": { "type": "string", "const": "hard" },
            "specRef": { "type": "string", "const": "4" },
            "note": { "type": "string", "const": "This pattern matches VIOLATIONS — presence of this pattern means the name is INVALID." }
          }
        }
      },
      "required": [
        "service-id", "package-short-id", "package-name", "capability-id",
        "provider-instance", "env-var", "urn", "vector-collection",
        "embedding-model-alias", "retrieval-pipeline-id", "search-index-id",
        "graph-node-id", "graph-db-index-id", "timestamped-id",
        "content-addressed-id", "uuid-based-id", "forbidden-legacy-prefix"
      ]
    }
  },
  "required": ["rules"]
}
