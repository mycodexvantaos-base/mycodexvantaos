{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/schemas/embedding-model-alias.schema.json",
  "title": "MyCodexVantaOS Embedding Model Alias",
  "description": "Schema for vector-store/embedding-model-aliases/*.yaml. Based on naming-spec-v1.md 9.3.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "type": "string", "const": "mycodexvantaos.org/v1" },
    "kind": { "type": "string", "const": "EmbeddingModelAlias" },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+--[a-z0-9-]+--[0-9]+d$",
          "description": "9.3 — Format: <provider>--<model-name>--<dimension>d"
        },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "spec": {
      "type": "object",
      "required": ["provider", "modelName", "dimension"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Embedding provider (e.g. 'openai', 'cohere', 'ollama')."
        },
        "modelName": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Model name in kebab-case (e.g. 'text-embedding-3-small')."
        },
        "dimension": {
          "type": "integer",
          "minimum": 1,
          "description": "Output vector dimension."
        },
        "providerInstance": {
          "type": "string",
          "pattern": "^embedding-[a-z0-9-]+$",
          "description": "8.1 — The provider-instance used for this model."
        },
        "maxTokens": { "type": "integer", "minimum": 1 },
        "description": { "type": "string" }
      }
    }
  }
}
