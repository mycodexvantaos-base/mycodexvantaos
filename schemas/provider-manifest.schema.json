{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/schemas/provider-manifest.schema.json",
  "title": "MyCodexVantaOS Provider Manifest",
  "description": "Schema for providers/<capability>/<provider-instance>/provider-manifest.yaml. Based on naming-spec-v1.md 8.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "type": "string", "const": "mycodexvantaos.org/v1" },
    "kind": { "type": "string", "const": "Provider" },
    "metadata": {
      "type": "object",
      "required": ["name", "capability"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(database|storage|auth|queue|state-store|secrets|repo|deploy|validation|security|observability|notification|scheduler|vector-store|embedding|llm|graph|cache|search)-[a-z0-9-]+$",
          "description": "8.1 — Provider instance name: <capability>-<provider-name>."
        },
        "capability": {
          "type": "string",
          "enum": [
            "database", "storage", "auth", "queue", "state-store",
            "secrets", "repo", "deploy", "validation", "security",
            "observability", "notification", "scheduler", "vector-store",
            "embedding", "llm", "graph", "cache", "search"
          ],
          "description": "5.5, 8.2 — Must be a canonical capability-id. Vendor names forbidden."
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["providerName", "lifecycle"],
      "additionalProperties": false,
      "properties": {
        "providerName": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Concrete vendor or implementation name (e.g. 'postgres', 'pgvector', 'openai')."
        },
        "isNative": {
          "type": "boolean",
          "description": "True if this provider is a native/open-source implementation without vendor lock-in."
        },
        "configSchemaRef": {
          "type": "string",
          "description": "Relative path to the config.schema.json for this provider."
        },
        "lifecycle": {
          "type": "object",
          "required": ["stage"],
          "properties": {
            "stage": {
              "type": "string",
              "enum": ["experimental", "alpha", "beta", "stable", "deprecated", "archived"]
            }
          }
        },
        "envVarPrefix": {
          "type": "string",
          "pattern": "^MYCODEXVANTAOS_[A-Z0-9_]+$",
          "description": "7.2 — The env var prefix used for this provider's configuration."
        },
        "description": { "type": "string" }
      }
    }
  }
}
