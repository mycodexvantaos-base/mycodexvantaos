{
  "name": "mycodexvantaos",
  "private": true,
  "version": "1.0.0",
  "description": "MyCodexVantaOS platform monorepo root",
  "scripts": {
    "dev": "vite",
    "dev:next": "next dev -p 3000",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "tsc -b && vite build",
    "build:next": "NODE_ENV=production next build",
    "build:packages": "tsc -b",
    "build:modules": "tsc -b modules/mycodexvantaos-ai-team-orchestrator modules/mycodexvantaos-persona-engine modules/mycodexvantaos-agent-toolkit",
    "preview": "vite preview",
    "start:next": "next start",
    "validate": "ts-node ci/validate-architecture.ts",
    "validate:github": "ts-node ci/validate-architecture.ts --reporter=github",
    "validate:json": "ts-node ci/validate-architecture.ts --reporter=json",
    "ci:validate": "ts-node ci/validate-architecture.ts",
    "check-legacy": "./scripts/check-legacy-prefix.sh .",
    "scan-drift": "./scripts/scan-naming-drift.sh --output=naming-drift-backlog.yaml",
    "check-exceptions": "./scripts/expire-exceptions.sh",
    "scaffold": "./scripts/generate-service-scaffold.sh",
    "test": "jest --runInBand --passWithNoTests",
    "test:coverage": "jest --coverage --runInBand --passWithNoTests",
    "test:modules": "jest --testPathPattern='modules/' --passWithNoTests",
    "test:services": "jest --testPathPattern='services/' --passWithNoTests",
    "lint": "next lint",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' 'modules/*/src/**/*.ts' --ignore-pattern '*.d.ts' --fix || true",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'modules/*/src/**/*.ts' 'packages/*/__tests__/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts' 'modules/*/src/**/*.ts' 'packages/*/__tests__/**/*.ts' || true",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/eventemitter3": "^2.0.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^20",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.45.0",
    "genkit-cli": "^1.28.0",
    "jest": "^29.5.0",
    "postcss": "^8",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^8.0.8",
    "yaml": "^2.8.3"
  },
  "workspaces": [
    "packages/*",
    "modules/*",
    "services/*",
    "providers/*"
  ],
  "dependencies": {
    "@genkit-ai/google-genai": "^1.28.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "eventemitter3": "^5.0.4",
    "firebase": "^11.9.1",
    "genkit": "^1.28.0",
    "lucide-react": "^0.475.0",
    "next": "^15.5.9",
    "patch-package": "^8.0.0",
    "react": "^19.2.1",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "zod": "^3.24.2"
  }
}