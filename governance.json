{
  "version": "1.0.0",
  "platform": "mycodexvantaos",
  "principles": [
    "local-first",
    "cloud-agnostic",
    "contract-first",
    "governance-enforced"
  ],
  "enforcement": {
    "ci_pipeline": "strict",
    "naming_conventions": "enforced",
    "capability_declarations": "required",
    "architecture_compliance": "mandatory"
  },
  "layers": [
    {
      "name": "Builder",
      "packages": [
        "@mycodexvantaos/builder"
      ],
      "capabilities": [
        "urn:mycodexvantaos:capability:builder"
      ]
    },
    {
      "name": "Runtime",
      "packages": [
        "@mycodexvantaos/runtime"
      ],
      "capabilities": [
        "urn:mycodexvantaos:capability:runtime"
      ]
    },
    {
      "name": "Deployment",
      "packages": [
        "@mycodexvantaos/deployment"
      ],
      "capabilities": []
    },
    {
      "name": "Native Services",
      "packages": [
        "@mycodexvantaos/service-discovery",
        "@mycodexvantaos/config-sync",
        "@mycodexvantaos/storage",
        "@mycodexvantaos/database",
        "@mycodexvantaos/events",
        "@mycodexvantaos/monitoring"
      ],
      "capabilities": [
        "urn:mycodexvantaos:capability:service-discovery",
        "urn:mycodexvantaos:capability:config-sync",
        "urn:mycodexvantaos:capability:storage",
        "urn:mycodexvantaos:capability:database",
        "urn:mycodexvantaos:capability:events",
        "urn:mycodexvantaos:capability:monitoring"
      ]
    }
  ],
  "validation_rules": {
    "package_naming": {
      "pattern": "@mycodexvantaos/*",
      "enforcement": "strict"
    },
    "urn_format": {
      "pattern": "^urn:mycodexvantaos:[a-z-]+:[a-z-]+:[a-z0-9-]+$",
      "enforcement": "strict"
    },
    "capability_declaration": {
      "required": true,
      "location": "capabilities/"
    }
  }
}