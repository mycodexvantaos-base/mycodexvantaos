{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/cache/redis/config.schema.json",
  "title": "cache-redis Configuration",
  "type": "object",
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_CACHE_REDIS_URL"
    },
    "keyPrefix": {
      "type": "string",
      "default": "mycodexvantaos:cache:"
    },
    "defaultTtlSeconds": {
      "type": "integer",
      "default": 300
    },
    "maxMemoryMb": {
      "type": "integer",
      "default": 256
    }
  }
}
