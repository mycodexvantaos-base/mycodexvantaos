{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/secrets/k8s-native/config.schema.json",
  "title": "secrets-k8s-native Configuration",
  "type": "object",
  "required": [
    "namespace"
  ],
  "properties": {
    "namespace": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_SECRETS_K8S_NAMESPACE",
      "default": "mycodexvantaos-prod"
    },
    "labelSelector": {
      "type": "string",
      "default": "app.kubernetes.io/managed-by=mycodexvantaos"
    }
  }
}
