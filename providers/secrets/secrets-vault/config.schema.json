{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/secrets/vault/config.schema.json",
  "title": "secrets-vault Configuration",
  "type": "object",
  "required": [
    "address"
  ],
  "properties": {
    "address": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_SECRETS_VAULT_ADDR"
    },
    "token": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_SECRETS_VAULT_TOKEN"
    },
    "mountPath": {
      "type": "string",
      "default": "secret"
    }
  }
}
