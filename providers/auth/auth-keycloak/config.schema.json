{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/auth/keycloak/config.schema.json",
  "title": "auth-keycloak Configuration",
  "type": "object",
  "required": [
    "serverUrl"
  ],
  "properties": {
    "serverUrl": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_AUTH_SERVER_URL"
    },
    "realm": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_AUTH_REALM"
    },
    "clientId": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_AUTH_CLIENT_ID"
    },
    "clientSecret": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_AUTH_CLIENT_SECRET"
    }
  }
}
