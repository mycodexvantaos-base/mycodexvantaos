{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/vector-store/qdrant/config.schema.json",
  "title": "vector-store-qdrant Configuration",
  "type": "object",
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_VECTOR_STORE_QDRANT_URL"
    },
    "apiKey": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_VECTOR_STORE_QDRANT_API_KEY"
    },
    "timeout": {
      "type": "integer",
      "default": 30
    }
  }
}
