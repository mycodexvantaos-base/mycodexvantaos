{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/state-store/redis/config.schema.json",
  "title": "state-store-redis Configuration",
  "type": "object",
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_STATE_STORE_URL"
    },
    "keyPrefix": {
      "type": "string",
      "default": "mycodexvantaos:state:"
    },
    "ttlSeconds": {
      "type": "integer",
      "default": 3600
    }
  }
}
