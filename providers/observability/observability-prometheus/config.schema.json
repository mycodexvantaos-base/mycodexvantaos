{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/observability/prometheus/config.schema.json",
  "title": "observability-prometheus Configuration",
  "type": "object",
  "required": [],
  "properties": {
    "metricsPath": {
      "type": "string",
      "default": "/metrics"
    },
    "port": {
      "type": "integer",
      "default": 9090
    },
    "scrapeIntervalSeconds": {
      "type": "integer",
      "default": 15
    }
  }
}
