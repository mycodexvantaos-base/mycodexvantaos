{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/llm/anthropic/config.schema.json",
  "title": "llm-anthropic Configuration",
  "type": "object",
  "required": [
    "apiKey"
  ],
  "properties": {
    "apiKey": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_LLM_ANTHROPIC_API_KEY"
    },
    "defaultModel": {
      "type": "string",
      "default": "claude-3-5-sonnet-20241022"
    },
    "maxTokens": {
      "type": "integer",
      "default": 8192
    }
  }
}
