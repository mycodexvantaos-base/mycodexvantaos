{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/queue/kafka/config.schema.json",
  "title": "queue-kafka Configuration",
  "type": "object",
  "required": [
    "brokers"
  ],
  "properties": {
    "brokers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "envVar": "MYCODEXVANTAOS_QUEUE_KAFKA_BROKERS"
    },
    "groupId": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_QUEUE_KAFKA_GROUP_ID"
    }
  }
}
