{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/queue/rabbitmq/config.schema.json",
  "title": "queue-rabbitmq Configuration",
  "type": "object",
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_QUEUE_URL"
    },
    "exchange": {
      "type": "string",
      "default": "mycodexvantaos"
    },
    "prefetch": {
      "type": "integer",
      "default": 10
    }
  }
}
