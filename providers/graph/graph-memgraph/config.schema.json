{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/graph/memgraph/config.schema.json",
  "title": "graph-memgraph Configuration",
  "type": "object",
  "required": [
    "host"
  ],
  "properties": {
    "host": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_GRAPH_MEMGRAPH_HOST",
      "default": "localhost"
    },
    "port": {
      "type": "integer",
      "default": 7687
    },
    "username": {
      "type": "string",
      "default": ""
    },
    "password": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_GRAPH_MEMGRAPH_PASSWORD"
    }
  }
}
