{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/embedding/cohere/config.schema.json",
  "title": "embedding-cohere Configuration",
  "type": "object",
  "required": [
    "apiKey"
  ],
  "properties": {
    "apiKey": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_EMBEDDING_COHERE_API_KEY"
    },
    "defaultModel": {
      "type": "string",
      "default": "embed-english-v3.0"
    },
    "inputType": {
      "type": "string",
      "enum": [
        "search_document",
        "search_query",
        "classification",
        "clustering"
      ],
      "default": "search_document"
    }
  }
}
