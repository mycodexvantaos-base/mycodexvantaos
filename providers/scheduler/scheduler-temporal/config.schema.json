{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/scheduler/temporal/config.schema.json",
  "title": "scheduler-temporal Configuration",
  "type": "object",
  "required": [
    "hostPort"
  ],
  "properties": {
    "hostPort": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_SCHEDULER_TEMPORAL_HOST",
      "default": "localhost:7233"
    },
    "namespace": {
      "type": "string",
      "default": "mycodexvantaos"
    },
    "taskQueue": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_SCHEDULER_TASK_QUEUE"
    }
  }
}
