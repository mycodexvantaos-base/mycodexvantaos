{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/database/postgres/config.schema.json",
  "title": "database-postgres Configuration",
  "type": "object",
  "required": [
    "connectionUrl"
  ],
  "properties": {
    "connectionUrl": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_DATABASE_URL",
      "description": "PostgreSQL connection URL"
    },
    "maxConnections": {
      "type": "integer",
      "default": 10
    },
    "ssl": {
      "type": "boolean",
      "default": false
    }
  }
}
