{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/database/sqlite/config.schema.json",
  "title": "database-sqlite Configuration",
  "type": "object",
  "required": [
    "filePath"
  ],
  "properties": {
    "filePath": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_DATABASE_SQLITE_PATH",
      "description": "SQLite file path"
    },
    "walMode": {
      "type": "boolean",
      "default": true
    }
  }
}
