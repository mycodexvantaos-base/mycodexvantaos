{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mycodexvantaos.org/providers/notification/sendgrid/config.schema.json",
  "title": "notification-sendgrid Configuration",
  "type": "object",
  "required": [
    "apiKey"
  ],
  "properties": {
    "apiKey": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_NOTIFICATION_SENDGRID_API_KEY"
    },
    "fromEmail": {
      "type": "string",
      "envVar": "MYCODEXVANTAOS_NOTIFICATION_FROM_EMAIL"
    },
    "fromName": {
      "type": "string",
      "default": "MyCodexVantaOS"
    }
  }
}
