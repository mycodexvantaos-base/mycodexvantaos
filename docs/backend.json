
{
  "entities": {
    "NodeCapability": {
      "title": "Node Capability Card",
      "description": "JSON schema for the Capability Discovery Protocol (Month 1)",
      "type": "object",
      "properties": {
        "node_id": { "type": "string" },
        "name": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "task_type": { "type": "string" },
              "confidence_range": { "type": "string" },
              "cost_per_inference": { "type": "number" },
              "latency_ms": { "type": "number" }
            }
          }
        },
        "public_key": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["node_id", "name", "capabilities"]
    },
    "AutonomousTask": {
      "title": "Autonomous Emergent Task",
      "description": "A task generated by the Global Pulse Sensing matrix (Month 3)",
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "anomaly_score": { "type": "number" },
        "source": { "type": "string" },
        "description": { "type": "string" },
        "status": { "enum": ["EVOLVING", "FORGING", "DISPATCHED", "RESOLVED"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/nodes/{nodeId}": {
      "schema": "#/backend/entities/NodeCapability",
      "description": "Registry of global expert nodes."
    },
    "/emergent_tasks/{taskId}": {
      "schema": "#/backend/entities/AutonomousTask",
      "description": "Tasks generated by the Global Pulse sensing matrix."
    }
  }
}
